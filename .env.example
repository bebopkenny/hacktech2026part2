# Copy to .env — never commit .env
# Same file lives in two places:
#   - your laptop (for `make serve-backend` local dev)
#   - /opt/sentinelai/.env on the Vultr box (read by docker-compose)

# K2-Think-v2 reasoning model — get key at https://api.k2think.ai
K2_API_KEY=your-k2-key-here
K2_BASE_URL=https://api.k2think.ai/v1
K2_MODEL=MBZUAI-IFM/K2-Think-v2
