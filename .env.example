# Copy to .env — never commit .env
# Same file lives in two places:
#   - your laptop (for `make serve-backend` local dev)
#   - /opt/sentinelai/.env on the Vultr box (read by docker-compose)

# K2-Think-v2 reasoning model — get key at https://api.k2think.ai
K2_API_KEY=your-k2-key-here
K2_BASE_URL=https://api.k2think.ai/v1
K2_MODEL=MBZUAI-IFM/K2-Think-v2
# Number of concurrent K2 calls per scan. ~5 cuts wall-clock 5× on big repos.
# Bump higher if K2 doesn't 429; drop to 1 to debug sequential issues.
K2_PARALLEL=5

# Semgrep authentication — required for p/ registry rulesets in Docker/Vultr.
# Get your token: run `semgrep login` locally, then `cat ~/.semgrep/settings.yml`
SEMGREP_APP_TOKEN=your-semgrep-token-here

# Backboard — persistent per-repo memory layer. Optional: if unset, the
# pipeline still works, just without cross-scan memory.
# Sign up at https://app.backboard.io/signup
BACKBOARD_API_KEY=your-backboard-key-here
BACKBOARD_MODEL=gpt-4o-mini

# GitHub webhook integration — unlocks auto-rescan on push.
# Both vars must be set for /scan to register a hook on the user's repo.
# Generate the secret with: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=
# Publicly reachable URL of THIS backend (where GitHub sends push events).
#   Vultr deploy:  http://107.191.50.160:8000
#   Local dev:     ngrok URL, e.g. https://abc123.ngrok-free.app
PUBLIC_WEBHOOK_URL=
